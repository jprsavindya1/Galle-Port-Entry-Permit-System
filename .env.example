# ============================================================================
# SLPA PORT ENTRY PERMIT SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================================================
# 
# This file contains all environment-specific configuration for the application.
# Copy this file to .env and update the values according to your environment.
#
# IMPORTANT SECURITY NOTES:
# - Never commit the .env file to version control
# - Use strong, unique passwords for production
# - Change all default values before deployment
# - Keep this file secure and restrict access
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env  (Linux/Mac) or copy .env.example .env (Windows)
# 2. Generate APP_KEY: php artisan key:generate
# 3. Configure database credentials
# 4. Configure mail settings
# 5. Run migrations: php artisan migrate
# ============================================================================

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------
# APP_NAME: The name of your application (used in emails, notifications, etc.)
# APP_ENV: Environment type (local, staging, production)
# APP_KEY: Application encryption key (REQUIRED - generate with: php artisan key:generate)
# APP_DEBUG: Enable debug mode (MUST be false in production for security)
# APP_URL: Full URL of your application (include https:// in production)
# ----------------------------------------------------------------------------

APP_NAME="SLPA Permit System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Application timezone (Asia/Colombo for Sri Lanka)
APP_TIMEZONE=UTC

# Locale settings
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance mode settings
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP server workers (adjust based on your needs)
PHP_CLI_SERVER_WORKERS=4

# Password hashing rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# ----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# ----------------------------------------------------------------------------
# LOG_CHANNEL: Logging channel (single, daily, stack, syslog, errorlog)
# LOG_STACK: Stack channels (single, daily, slack, etc.)
# LOG_LEVEL: Minimum log level (debug, info, notice, warning, error, critical, alert, emergency)
# 
# PRODUCTION RECOMMENDATION:
# - LOG_CHANNEL=stack
# - LOG_STACK=daily
# - LOG_LEVEL=error (to reduce log size)
# ----------------------------------------------------------------------------

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------
# Configure your database connection here.
# 
# DEVELOPMENT: Use local MySQL/MariaDB
# PRODUCTION: Use separate database user with strong password
#
# Database Setup:
# 1. Create database: CREATE DATABASE port_entry_permit CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# 2. Create user: CREATE USER 'your_user'@'localhost' IDENTIFIED BY 'secure_password';
# 3. Grant privileges: GRANT ALL PRIVILEGES ON port_entry_permit.* TO 'your_user'@'localhost';
# 4. Flush privileges: FLUSH PRIVILEGES;
# ----------------------------------------------------------------------------

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=port_entry_permit
DB_USERNAME=root
DB_PASSWORD=

# Optional: Database prefix (leave empty if not needed)
# DB_PREFIX=

# ----------------------------------------------------------------------------
# SESSION CONFIGURATION
# ----------------------------------------------------------------------------
# SESSION_DRIVER: Where to store sessions (file, cookie, database, redis, memcached)
# SESSION_LIFETIME: Session lifetime in minutes
# 
# PRODUCTION RECOMMENDATION: Use 'database' or 'redis' for better performance
# ----------------------------------------------------------------------------

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ----------------------------------------------------------------------------
# CACHE CONFIGURATION
# ----------------------------------------------------------------------------
# CACHE_STORE: Cache driver (file, database, redis, memcached)
# 
# PRODUCTION RECOMMENDATION: Use 'redis' for better performance
# ----------------------------------------------------------------------------

CACHE_STORE=database
CACHE_PREFIX=slpa_permit

# ----------------------------------------------------------------------------
# QUEUE CONFIGURATION
# ----------------------------------------------------------------------------
# QUEUE_CONNECTION: Queue driver (sync, database, redis, sqs, beanstalkd)
# 
# DEVELOPMENT: Use 'sync' for immediate processing
# PRODUCTION: Use 'database' or 'redis' with queue workers
# 
# To process queued jobs:
# php artisan queue:work --tries=3
# ----------------------------------------------------------------------------

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ----------------------------------------------------------------------------
# REDIS CONFIGURATION (Optional)
# ----------------------------------------------------------------------------
# Required only if using Redis for cache, sessions, or queues
# Install Redis: sudo apt install redis-server (Linux) or via Homebrew (Mac)
# ----------------------------------------------------------------------------

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1

# ----------------------------------------------------------------------------
# MEMCACHED CONFIGURATION (Optional)
# ----------------------------------------------------------------------------
# Required only if using Memcached for cache or sessions
# ----------------------------------------------------------------------------

MEMCACHED_HOST=127.0.0.1
# MEMCACHED_PORT=11211

# ----------------------------------------------------------------------------
# MAIL CONFIGURATION
# ----------------------------------------------------------------------------
# Configure email sending settings for notifications, invoices, etc.
# 
# MAIL_MAILER options:
# - smtp: Use SMTP server (Gmail, Outlook, custom SMTP)
# - log: Save emails to log file (for testing)
# - sendmail: Use server's sendmail
# - mailgun: Use Mailgun service
# - ses: Use Amazon SES
#
# Gmail Setup (requires App Password):
# 1. Enable 2-Step Verification on your Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use App Password in MAIL_PASSWORD (not your regular password)
#
# PRODUCTION SETTINGS:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@slpa.lk
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@slpa.lk
# MAIL_FROM_NAME="SLPA Permit System"
# ----------------------------------------------------------------------------

MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ----------------------------------------------------------------------------
# AWS CONFIGURATION (Optional)
# ----------------------------------------------------------------------------
# Required only if using AWS services (S3 for file storage, SES for email, etc.)
# ----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ----------------------------------------------------------------------------
# PAYMENT GATEWAY CONFIGURATION (If applicable)
# ----------------------------------------------------------------------------
# Add your payment gateway credentials here if integrated
# ----------------------------------------------------------------------------

# PAYMENT_GATEWAY=
# PAYMENT_MERCHANT_ID=
# PAYMENT_SECRET_KEY=
# PAYMENT_CURRENCY=LKR
# PAYMENT_MODE=test

# ----------------------------------------------------------------------------
# THIRD-PARTY SERVICES (If applicable)
# ----------------------------------------------------------------------------
# Add any third-party API keys or service credentials here
# ----------------------------------------------------------------------------

# SMS_API_KEY=
# SMS_SENDER_ID=
# SMS_PROVIDER=

# ----------------------------------------------------------------------------
# SECURITY SETTINGS
# ----------------------------------------------------------------------------
# Additional security configurations
# ----------------------------------------------------------------------------

# Rate limiting (requests per minute)
# RATE_LIMIT_PER_MINUTE=60

# Password reset token expiry (minutes)
# PASSWORD_RESET_TIMEOUT=60

# Session timeout warning (minutes before expiry)
# SESSION_TIMEOUT_WARNING=5

# ----------------------------------------------------------------------------
# VITE (Frontend Build Tool)
# ----------------------------------------------------------------------------
# Used for compiling frontend assets (CSS, JavaScript)
# ----------------------------------------------------------------------------

VITE_APP_NAME="${APP_NAME}"

# ----------------------------------------------------------------------------
# DEVELOPMENT/DEBUG TOOLS (Remove in production)
# ----------------------------------------------------------------------------
# These should be commented out or removed in production environments
# ----------------------------------------------------------------------------

# TELESCOPE_ENABLED=false
# DEBUGBAR_ENABLED=false

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# 
# Before deploying to production, ensure:
# 
# 1. SECURITY:
#    □ APP_ENV=production
#    □ APP_DEBUG=false
#    □ APP_KEY is generated (php artisan key:generate)
#    □ All passwords are strong and unique
#    □ HTTPS is enabled (APP_URL starts with https://)
#    □ Mail credentials are for production email account
#    □ Database user has minimal required privileges
#
# 2. PERFORMANCE:
#    □ CACHE_STORE=redis (recommended)
#    □ SESSION_DRIVER=redis (recommended)
#    □ QUEUE_CONNECTION=redis or database
#    □ LOG_LEVEL=error (to minimize log file size)
#
# 3. CONFIGURATION:
#    □ Run: php artisan config:cache
#    □ Run: php artisan route:cache
#    □ Run: php artisan view:cache
#    □ Run: composer install --optimize-autoloader --no-dev
#
# 4. TESTING:
#    □ Test login functionality
#    □ Test permit creation
#    □ Test email sending
#    □ Test PDF generation
#    □ Test payment processing
#    □ Test all critical features
#
# 5. MONITORING:
#    □ Set up error monitoring (e.g., Sentry)
#    □ Configure log rotation
#    □ Set up automated backups
#    □ Configure queue workers with Supervisor
#    □ Set up cron jobs for scheduled tasks
#
# ============================================================================
# ENVIRONMENT-SPECIFIC EXAMPLES
# ============================================================================
#
# DEVELOPMENT (.env.local):
# --------------------------
# APP_ENV=local
# APP_DEBUG=true
# APP_URL=http://localhost:8000
# DB_DATABASE=port_entry_permit_dev
# MAIL_MAILER=log
# QUEUE_CONNECTION=sync
# CACHE_STORE=file
#
# STAGING (.env.staging):
# --------------------------
# APP_ENV=staging
# APP_DEBUG=true
# APP_URL=https://staging.permit.slpa.lk
# DB_DATABASE=port_entry_permit_staging
# MAIL_MAILER=smtp
# QUEUE_CONNECTION=database
# CACHE_STORE=redis
#
# PRODUCTION (.env.production):
# --------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://permit.slpa.lk
# DB_DATABASE=port_entry_permit_prod
# DB_USERNAME=slpa_prod_user
# DB_PASSWORD=secure_random_password
# MAIL_MAILER=smtp
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# LOG_LEVEL=error
#
# ============================================================================
